{
  "name": "tool-bridge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:unit": "pnpm --filter @tool-bridge/core --filter @tool-bridge/cli --filter @tool-bridge/sdk test",
    "test:integration": "pnpm --filter @tool-bridge/gateway --filter @tool-bridge/server --filter @tool-bridge/plugin-feishu test",
    "test": "pnpm -r --if-present test",
    "verify": "pnpm typecheck && pnpm lint && pnpm test:unit && pnpm test:integration",
    "gen-dev-vars": "node scripts/gen-dev-vars.mjs",
    "provision": "node scripts/provision.mjs",
    "smoke": "tsx scripts/smoke.ts",
    "deploy:all": "node scripts/provision.mjs && pnpm --filter @tool-bridge/dashboard build && pnpm --filter @tool-bridge/gateway run deploy",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^9.39.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsonc": "^2.21.1",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "wrangler": "4.107.0"
  }
}
