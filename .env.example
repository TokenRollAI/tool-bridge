# tool-bridge 环境变量模板
# 复制为 .env 并填入真实值;.env 不入库(.gitignore)。
# 本地开发的 .dev.vars 由 scripts/gen-dev-vars.mjs 从 .env 白名单生成,不要手工维护两份。

# ============================================================
# Cloudflare(部署目标;操作经本地 wrangler OAuth,无需 API Token)
# ============================================================
# 账户:DJJ(已用 `wrangler whoami` 确认)
CLOUDFLARE_ACCOUNT_ID=

# 可选:CI/无头环境用 API Token 代替本地 wrangler OAuth 登录。
# 本地开发留空即可(wrangler 用你已登录的 OAuth 凭据)。
# 注意:Account-scoped token 的验证一律用 `wrangler whoami`,勿用 /user/tokens/verify(必然误报)。
# CLOUDFLARE_API_TOKEN=

# ============================================================
# 部署形态
# ============================================================
# 生产 BaseURL(custom domain;zone pdjjq.org 在 DJJ 账户下,Watt 已验证可挂)
TB_DOMAIN=
TB_BASE_URL=

# 云上资源统一前缀(worker/KV/R2 命名派生:tb-gateway / tb-state / tb-context)
TB_NAME_PREFIX=tb

# ============================================================
# 信任根(env-only,不走 SecretStore 回退)
# ============================================================
# SecretStore 主密钥:32 字节 base64url。生成:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# 经 `wrangler secret put TB_SECRET_ENCRYPTION_KEY` 注入生产;本地进 .dev.vars。
TB_SECRET_ENCRYPTION_KEY=

# ============================================================
# R2 预签名($ref 大对象直连下载)
# ============================================================
# R2 binding 不支持 presign——需要一对 R2 S3 兼容 Access Key(Dashboard → R2 → Manage API Tokens 创建,
# 权限:Object Read & Write,限定 tb-context bucket)。留空则大对象走网关中转下载(功能不缺,带宽走 Worker)。
# 部署后建议改经 `tb secret set` 存入 SecretStore,而非长期留在 .env。
# TB_R2_ACCESS_KEY_ID=
# TB_R2_SECRET_ACCESS_KEY=

# ============================================================
# CLI / 测试驱动(E2E 与集成测试用)
# ============================================================
# `tb` CLI 的默认目标(也可用 `tb use <server>` 管理多目标)
TB_SK=            # 部署后由 tb init 输出的 Admin SK 填入(明文只输出一次)

# Phase 2 / E2E-5 的真实上游 MCP server(Streamable HTTP);
# 留空则测试用自建 echo MCP 兜底
# TB_TEST_MCP_URL=
# TB_TEST_MCP_BEARER=

# Phase 3 / E2E-2 的"外部 S3"兼容端点(用 DJJ 账户 R2 的 S3 API 即可:
#   https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com)
# TB_TEST_S3_ENDPOINT=
# TB_TEST_S3_ACCESS_KEY_ID=
# TB_TEST_S3_SECRET_ACCESS_KEY=
# TB_TEST_S3_BUCKET=
