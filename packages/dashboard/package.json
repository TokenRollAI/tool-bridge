{
  "name": "@tool-bridge/dashboard",
  "version": "0.2.0",
  "description": "tool-bridge dashboard as prebuilt static assets (Vite build output in dist/), serve via Workers Static Assets or any static host",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "tool-bridge",
    "dashboard",
    "static-assets"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@fontsource-variable/ibm-plex-sans": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@rjsf/core": "^6.6.2",
    "@rjsf/shadcn": "^6.6.2",
    "@rjsf/utils": "^6.6.2",
    "@rjsf/validator-ajv8": "^6.6.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.1.16",
    "@tanstack/react-query": "^5.90.5",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.545.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router": "^7.9.4",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.16",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TokenRollAI/tool-bridge.git",
    "directory": "packages/dashboard"
  }
}
