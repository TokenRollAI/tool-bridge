{
  "name": "@tool-bridge/cli",
  "version": "0.1.1",
  "description": "tb — Tool Bridge CLI: one gateway for HTBP/MCP/HTTP tools, contexts, and device shells",
  "type": "module",
  "license": "MIT",
  "bin": {
    "tb": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cli",
    "mcp",
    "htbp",
    "tool-bridge",
    "agent-tools"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "partysocket": "1.3.0",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@tool-bridge/core": "workspace:*",
    "@types/node": "^26.1.0",
    "@types/ws": "8.18.1",
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  }
}
