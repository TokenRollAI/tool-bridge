{
  "name": "@tool-bridge/sdk",
  "version": "0.4.0",
  "description": "tool-bridge SDK: embed a TB instance (createToolBridge), register local providers, and connect to a remote gateway",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "sdk",
    "mcp",
    "htbp",
    "tool-bridge",
    "agent-tools"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "aws4fetch": "^1.0.20",
    "hono": "^4.12.28",
    "partysocket": "1.3.0",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.7",
    "@tool-bridge/core": "workspace:*",
    "@tool-bridge/gateway": "workspace:*",
    "@types/node": "^26.1.0",
    "@types/ws": "8.18.1",
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TokenRollAI/tool-bridge.git",
    "directory": "packages/sdk"
  }
}
