{
  "name": "@tool-bridge/gateway",
  "version": "0.2.0",
  "description": "tool-bridge gateway as a Cloudflare Worker library: default-export the HTBP app plus the DeviceSession Durable Object, deploy with your own wrangler config",
  "type": "module",
  "license": "MIT",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tbApp": "./src/tbApp.ts",
    "./bootstrap": "./src/bootstrap.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "keywords": [
    "cloudflare-workers",
    "mcp",
    "htbp",
    "tool-bridge",
    "agent-tools"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "wrangler dev",
    "build": "tsup",
    "deploy": "wrangler deploy",
    "echo-mcp": "tsx scripts/echo-mcp.ts",
    "s3-mock": "tsx scripts/s3-mock.ts",
    "stub-provider": "tsx scripts/stub-provider.ts"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "aws4fetch": "^1.0.20",
    "hono": "^4.12.28"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "@cloudflare/workers-types": "^5.20260706.1",
    "@tool-bridge/core": "workspace:*",
    "s3rver": "^3.7.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "vitest": "^4.1.10",
    "zod": "^3.25.76"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TokenRollAI/tool-bridge.git",
    "directory": "packages/gateway"
  }
}
